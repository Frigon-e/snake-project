---
// src/layouts/AdminLayout.astro
import BaseLayout from './BaseLayout.astro';
import { UserButton } from '@clerk/astro/components';

interface Props {
  title: string;
  noPadding?: boolean;
}
const { title, noPadding = false } = Astro.props;
const pathname = Astro.url.pathname;

const navItems = [
  {
    label: 'Overview',
    href: '/admin',
    active: pathname === '/admin',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3.75 6A2.25 2.25 0 0 1 6 3.75h2.25A2.25 2.25 0 0 1 10.5 6v2.25a2.25 2.25 0 0 1-2.25 2.25H6a2.25 2.25 0 0 1-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 0 1 6 13.5h2.25a2.25 2.25 0 0 1 2.25 2.25V18a2.25 2.25 0 0 1-2.25 2.25H6A2.25 2.25 0 0 1 3.75 18v-2.25zM13.5 6a2.25 2.25 0 0 1 2.25-2.25H18A2.25 2.25 0 0 1 20.25 6v2.25A2.25 2.25 0 0 1 18 10.5h-2.25a2.25 2.25 0 0 1-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 0 1 2.25-2.25H18a2.25 2.25 0 0 1 2.25 2.25V18A2.25 2.25 0 0 1 18 20.25h-2.25A2.25 2.25 0 0 1 13.5 18v-2.25z"/></svg>`,
  },
  {
    label: 'Inventory',
    href: '/admin/snakes',
    active: pathname.startsWith('/admin/snakes'),
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9.568 3H5.25A2.25 2.25 0 0 0 3 5.25v4.318c0 .597.237 1.17.659 1.591l9.581 9.581c.699.699 1.78.872 2.607.33a18.095 18.095 0 0 0 5.223-5.223c.542-.827.369-1.908-.33-2.607L11.16 3.66A2.25 2.25 0 0 0 9.568 3z"/><path d="M6 6h.008v.008H6V6z"/></svg>`,
  },
  {
    label: 'Media',
    href: '/admin/media',
    active: pathname.startsWith('/admin/media'),
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 0 0 1.5-1.5V6a1.5 1.5 0 0 0-1.5-1.5H3.75A1.5 1.5 0 0 0 2.25 6v12a1.5 1.5 0 0 0 1.5 1.5zm10.5-11.25h.008v.008h-.008V8.25zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0z"/></svg>`,
  },
  {
    label: 'Settings',
    href: '/admin/settings',
    active: pathname.startsWith('/admin/settings'),
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.325.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 0 1 1.37.49l1.296 2.247a1.125 1.125 0 0 1-.26 1.431l-1.003.827c-.293.241-.438.613-.43.992a7.723 7.723 0 0 1 0 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.955.26 1.43l-1.298 2.247a1.125 1.125 0 0 1-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.47 6.47 0 0 1-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.94-1.11.94h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 0 1-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 0 1-1.369-.49l-1.297-2.247a1.125 1.125 0 0 1 .26-1.431l1.004-.827c.292-.24.437-.613.43-.991a6.932 6.932 0 0 1 0-.255c.007-.38-.138-.751-.43-.992l-1.004-.827a1.125 1.125 0 0 1-.26-1.43l1.297-2.247a1.125 1.125 0 0 1 1.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.086.22-.128.332-.183.582-.495.644-.869l.214-1.28ZM15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0z"/></svg>`,
  },
];
---
<BaseLayout title={`Admin — ${title}`}>
  <div slot="header" class="flex h-screen bg-surface overflow-hidden">
    <!-- Sidebar: 256px fixed -->
    <aside aria-label="Site navigation" class="w-64 shrink-0 bg-surface-container border-r border-outline-variant/15 flex flex-col h-full">
      <!-- Brand block -->
      <div class="px-4 pt-4 pb-8">
        <a href="/" class="flex items-center gap-3 px-2 rounded-md hover:bg-surface-container-high transition-colors py-1">
          <div class="w-10 h-10 bg-primary/10 rounded-sm flex items-center justify-center shrink-0">
            <span class="font-noto-serif text-primary font-bold text-sm leading-none">BCE</span>
          </div>
          <div class="flex flex-col gap-1">
            <p class="font-noto-serif text-tertiary font-bold text-lg leading-none">BC Exotix</p>
            <p class="text-[10px] uppercase tracking-[2px] text-on-surface/60">Admin Portal</p>
          </div>
        </a>
      </div>

      <!-- Nav -->
      <nav class="flex-1 flex flex-col gap-1 px-2 pt-2">
        {navItems.map(item => (
          <a
            href={item.href}
            class:list={[
              'flex items-center gap-3 px-3 py-[10px] rounded-md text-sm font-medium transition-colors',
              item.active
                ? 'bg-primary/10 text-primary'
                : 'text-on-surface/70 hover:bg-surface-container-high',
            ]}
          >
            {/* icon is a hardcoded literal string — safe for set:html */}
            <span class="shrink-0 w-5 h-5" set:html={item.icon} />
            {item.label}
          </a>
        ))}
      </nav>

      <!-- Bottom block — background shift, no border-t -->
      <div class="px-2 pt-4 pb-4 bg-surface-container-lowest">
        <a
          href="/admin/snakes/new"
          class="flex items-center justify-center gap-2 w-full bg-primary text-on-primary font-bold py-3 rounded-md text-sm hover:bg-primary/90 transition-colors mb-4"
        >
          + New Specimen
        </a>
        {/* TODO: link to support URL */}
        <a
          href="#"
          class="block text-center text-[11px] text-on-surface/40 hover:text-on-surface/60 transition-colors"
        >
          Support
        </a>
      </div>
    </aside>

    <!-- Main content area -->
    <div role="main" class="flex-1 flex flex-col min-w-0 overflow-auto">
      <!-- Top bar -->
      <header class="sticky top-0 z-10 backdrop-blur-md bg-surface/60 border-b border-outline-variant/15 flex items-center justify-between px-6 h-14 shrink-0">
        <h1 class="font-noto-serif text-primary text-xl font-bold">{title}</h1>
        <div class="flex items-center gap-4">
          <slot name="header-actions" />
          <div class="w-px h-8 bg-outline-variant/20"></div>
          <UserButton userProfileUrl="/admin/settings" />
        </div>
      </header>

      <!-- Content -->
      <div class:list={['flex-1', noPadding ? 'overflow-auto' : 'p-10']}>
        <slot />
      </div>
    </div>
  </div>
</BaseLayout>
