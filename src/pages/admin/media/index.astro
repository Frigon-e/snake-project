---
// src/pages/admin/media/index.astro
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { r2Key } from '../../../lib/r2';
import { env } from 'cloudflare:workers';
import type { R2Bucket } from '@cloudflare/workers-types';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const file = formData.get('file') as File | null;
  if (file && file.size > 0) {
    const key = r2Key(file.name);
    await (env as unknown as { ASSETS_BUCKET: R2Bucket }).ASSETS_BUCKET.put(key, await file.arrayBuffer(), {
      httpMetadata: { contentType: file.type },
    });
    return Astro.redirect(`/admin/media?uploaded=${encodeURIComponent(key)}`);
  }
}

const uploadedKey = new URL(Astro.request.url).searchParams.get('uploaded');
---
<AdminLayout title="Media">
  <div class="mb-8">
    <p class="text-primary text-[10px] uppercase tracking-[3px] font-bold mb-2">Asset Management</p>
    <h1 class="font-noto-serif text-on-surface text-4xl font-bold tracking-tight mb-2">Media Library</h1>
    <p class="text-on-surface/60 text-sm">Upload and manage images for your specimen collection.</p>
  </div>

  {uploadedKey && (
    <div class="bg-surface-container-low rounded-lg p-6 border border-outline-variant/5 mb-8">
      <div class="aspect-video max-w-sm rounded-sm overflow-hidden mb-4 bg-surface-container-lowest">
        <img src={`/api/r2/image?key=${encodeURIComponent(uploadedKey)}`} alt="Uploaded image" class="w-full h-full object-contain" />
      </div>
      <p class="text-primary text-xs uppercase tracking-[1.2px] font-bold mb-2">Upload Successful — R2 Key</p>
      <div class="flex items-center gap-2">
        <code class="flex-1 bg-surface-container-lowest text-on-surface/60 font-mono text-xs px-3 py-2 rounded-md break-all">{uploadedKey}</code>
        <button
          id="copy-key-btn"
          data-key={uploadedKey}
          class="shrink-0 text-primary text-xs font-bold uppercase tracking-[1px] hover:text-primary/80 transition-colors px-3 py-2 bg-primary/10 rounded-md"
        >
          Copy
        </button>
      </div>
      <script is:inline>
        const btn = document.getElementById('copy-key-btn');
        if (btn) {
          btn.addEventListener('click', () => {
            const key = btn.getAttribute('data-key') ?? '';
            navigator.clipboard.writeText(key).then(() => {
              btn.textContent = 'Copied!';
              setTimeout(() => { btn.textContent = 'Copy'; }, 1500);
            });
          });
        }
      </script>
      <p class="text-on-surface/40 text-xs mt-2">Paste this key into a specimen's Primary Image Key field.</p>
    </div>
  )}

  <section class="bg-surface-container-low rounded-lg shadow-[0px_0px_0px_1px_rgba(65,72,67,0.1)] p-8">
    <div class="flex items-center gap-2 mb-6">
      <p class="text-primary text-xs uppercase tracking-[1.8px] font-normal">Upload Image</p>
    </div>
    <form method="POST" enctype="multipart/form-data" class="flex flex-col gap-4">
      <div class="bg-surface-container-lowest rounded-md border border-outline-variant/15 flex items-center justify-between px-4 py-5">
        <div>
          <p class="text-on-surface text-xs font-bold uppercase tracking-wide">Select Image</p>
          <p class="text-on-surface/50 text-[10px]">Max size: 10MB · JPG, PNG, WebP</p>
        </div>
        <label for="file-input" class="text-primary text-[10px] uppercase tracking-[1px] font-bold hover:text-primary/80 transition-colors cursor-pointer">
          Browse
          <input id="file-input" type="file" name="file" accept="image/*" required class="sr-only" />
        </label>
      </div>
      <button type="submit" class="bg-primary text-on-primary font-bold text-sm px-6 py-3 rounded-md hover:bg-primary/90 transition-colors w-full">
        Upload Image
      </button>
    </form>
  </section>
</AdminLayout>
